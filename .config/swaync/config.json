{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 8,
  "control-center-width": 450,
  "control-center-height": 760,
  "fit-to-screen": false,

  "layer": "overlay",
  "cssPriority": "user",
  "notification-icon-size": 64,
  "notification-body-image-height": 64,
  "notification-body-image-width": 64,
  "timeout": 3,
  "timeout-low": 2,
  "timeout-critical": 0,
  "notification-window-width": 500,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 100,
  "hide-on-clear": true,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
 	"menubar#label",
 	"dnd",
 	"inhibitors",
 	"label",
 	"volume",
 	"backlight",
 	"mpris",
 	"title",
 	"notifications"
  ],
  "widget-config": {
    "menubar#label": {
      "menu#power-buttons": {
        "label": "⏻",
        "position": "right",
        "actions": [
          {
            "label": "Lock",
            "command": "swaync-client -t -sw && hyprlock"
          },
          {
            "label": "Log out",
            "command": "swaync-client -t -sw && command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch 'hl.dsp.exit()'"
          },
          {
            "label": " Suspend",
            "command": "swaync-client -t -sw && systemctl suspend"
          },
          {
            "label": " Reboot",
            "command": "swaync-client -t -sw && systemctl reboot"
          },
          {
            "label": "⏻ Shut down",
            "command": "swaync-client -t -sw && sudo shutdown"
          }
        ]
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "直",
          "command": "networkmanager_dmenu"
        },
        {
          "label": "",
          "command": "blueman-manager"
        }
      ]
    },
    "buttons#topbar-buttons": {
        "position": "left",
        "actions": [
          {
            "label": "",
            "command": "swaync-client -t -sw && grim -g \"$(slurp)\" - | wl-copy && wl-paste > ~/Pictures/Screenshot_$(date +%Y%m%d_%H%M%S).png && notify-send 'Screenshot' 'Region saved and copied'"
          },
          {
            "label": "󰈋",
            "command": "swaync-client -t -sw && hyprpicker -a && notify-send 'Color Picker' 'Hex code copied to clipboard!'"
          }
        ]
      }
    },
    "inhibitors": {
      "text": "Inhibidores",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "label": {
    "max-lines": 5,
    "text": "Controls"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 128,
      "image-radius": 8
    },
    "volume": {
      "label": " "
    },
   "backlight": {
      "label": " ",
      "device": "intel_backlight"
    }
   }
}
